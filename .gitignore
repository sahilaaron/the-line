# --- dependencies / builds ---
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# --- local databases / generated data (PGlite, synthetic, exports) ---
/.pglite-data/
/data/pglite/
*.pglite/
synthetic-*.json
db-export*.json
export-*.json
*.export.json
drizzle/meta/_journal.json.bak

# --- benchmark / audit runtime output (reports in docs/generated/*.md stay tracked) ---
docs/generated/*.tmp
docs/generated/*.json
benchmark-*.json

# --- env (keep safe examples) ---
.env
.env.*
!.env.example

# --- test / browser artifacts ---
test-results/
playwright-report/
coverage/
*.lcov
screenshots/
*.webm
*.mp4

# --- root debug debris (Cycle 3 audit; deleted, kept ignored defensively) ---
/pgtest*.mjs
/pgfork.mjs
/pgpersist*.mjs
/dbgimport*.mjs
/ztest.ts
/zverify-api.ts
/.trash/

# --- OS / editor ---
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp

# --- logs ---
*.log
npm-debug.log*
logs/

# --- temporary review evidence (issue/PR verification media) ---
# Attach visual evidence to GitHub PR comments or keep it as CI artifacts.
# Markdown documentation in docs/evidence/ remains tracked; binaries do not.
docs/evidence/**/*.png
docs/evidence/**/*.jpg
docs/evidence/**/*.jpeg
docs/evidence/**/*.gif
docs/evidence/**/*.webp
docs/evidence/**/*.webm
docs/evidence/**/*.mp4
